[global]
    # Appearance
    monitor = 0
    follow = mouse
    width = 300
    height = (0, 100)
    origin = bottom-right
    offset = (10, 10)
    padding = 12
    horizontal_padding = 12
    frame_width = 2
    frame_color = "#ffffff"
    separator_color = frame
    # corner_radius = 8
    notification_limit = 5

    # Fonts
    font = "JetBrainsMono Nerd Font 10"
    line_height = 4

    # Opacity
    transparency = 10

    # Notification timeouts
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = center
    show_age_threshold = 60
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = true

    # Icon settings
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64

    # Separator settings
    separator_height = 2

    # Close on mouse interaction
    mouse_left_click = close_current
    mouse_middle_click = close_all
    mouse_right_click = do_action

[urgency_low]
    background = "#10001b"  
    foreground = "#98c379"  
    frame_color = "#56b6c2" 
    timeout = 5

[urgency_normal]
    background = "#10001b"   
    foreground = "#ffffff"  
    frame_color = "#ffffff"  
    timeout = 10

[urgency_critical]
    background = "#10001b"  
    foreground = "#ffffff"   
    frame_color = "#bf616a"  
    timeout = 0
